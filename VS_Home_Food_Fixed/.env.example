# ═══════════════════════════════════════════════════════════════
#  Amma Vanta — .env Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

SECRET_KEY=change-this-to-any-long-random-string-abc123xyz

# ── Database (default: SQLite — no setup needed) ────────────────
# For MySQL, uncomment and fill:
# DATABASE_URL=mysql+pymysql://username:password@localhost/ammavanta_db

# ── Gmail SMTP ──────────────────────────────────────────────────
# Step 1: Enable 2-Step Verification at myaccount.google.com
# Step 2: Go to Security → App passwords → Generate for "Mail"
# Step 3: Paste the 16-digit code below (spaces OK)
MAIL_USERNAME=yourgmail@gmail.com
MAIL_PASSWORD=abcd efgh ijkl mnop

# ── Admin Details ───────────────────────────────────────────────
ADMIN_EMAIL=youremail@gmail.com
ADMIN_WHATSAPP=+919876543210
ADMIN_PASSWORD=your-secure-admin-password

# ── Twilio WhatsApp (Optional) ──────────────────────────────────
# Leave blank to skip WhatsApp notifications
# Get credentials at: console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
